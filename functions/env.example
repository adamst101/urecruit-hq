# Environment variables required for Deno functions
# Set these in the base44 dashboard:
#   Project Settings → Environment Variables
#
# ── Resend (monthly camp agenda emails) ──────────────────────────────────────
RESEND_API_KEY=re_YOUR_RESEND_API_KEY_HERE
RESEND_FROM_EMAIL=agenda@urecruithq.com

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_YOUR_STRIPE_SECRET_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# ── Other ─────────────────────────────────────────────────────────────────────
RYZER_AUTH=YOUR_RYZER_AUTH_TOKEN_HERE
SCORECARD_API_KEY=YOUR_SCORECARD_API_KEY_HERE
SUPPORT_EMAIL=support@urecruithq.com
